{
  "youtube": {
    "client_id": "YOUR_CLIENT_ID.apps.googleusercontent.com",
    "client_secret": "YOUR_CLIENT_SECRET",
    "redirect_uris": [
      "urn:ietf:wg:oauth:2.0:oob"
    ]
  },
  "normalizedAiExamples": {
    "geminiOnly": {
      "mode": "single",
      "primaryProvider": "gemini",
      "fallbackProvider": null,
      "enabledProviders": [
        "gemini"
      ],
      "selectedModels": {
        "gemini": "gemini-2.5-flash"
      },
      "providers": {
        "gemini": {
          "enabled": true,
          "apiKey": "GEMINI_API_KEY_PLACEHOLDER",
          "model": "gemini-2.5-flash"
        }
      }
    },
    "openaiPrimaryGeminiFallback": {
      "mode": "fallback",
      "primaryProvider": "openai",
      "fallbackProvider": "gemini",
      "enabledProviders": [
        "openai",
        "gemini"
      ],
      "selectedModels": {
        "openai": "MODEL_ID_SELECTED_DURING_SETUP",
        "gemini": "gemini-2.5-flash"
      },
      "providers": {
        "openai": {
          "enabled": true,
          "apiKey": "OPENAI_API_KEY_PLACEHOLDER",
          "model": "MODEL_ID_SELECTED_DURING_SETUP"
        },
        "gemini": {
          "enabled": true,
          "apiKey": "GEMINI_API_KEY_PLACEHOLDER",
          "model": "gemini-2.5-flash"
        }
      }
    },
    "deepseekOnly": {
      "mode": "single",
      "primaryProvider": "deepseek",
      "fallbackProvider": null,
      "enabledProviders": [
        "deepseek"
      ],
      "selectedModels": {
        "deepseek": "deepseek-chat"
      },
      "providers": {
        "deepseek": {
          "enabled": true,
          "apiKey": "DEEPSEEK_API_KEY_PLACEHOLDER",
          "model": "deepseek-chat",
          "baseUrl": "https://api.deepseek.com"
        }
      }
    },
    "customOpenAICompatible": {
      "mode": "single",
      "primaryProvider": "openai_compatible_custom",
      "fallbackProvider": null,
      "enabledProviders": [
        "openai_compatible_custom"
      ],
      "selectedModels": {
        "openai_compatible_custom": "custom-model"
      },
      "providers": {
        "openai_compatible_custom": {
          "enabled": true,
          "apiKey": "CUSTOM_LLM_API_KEY_PLACEHOLDER",
          "model": "custom-model",
          "baseUrl": "https://your-openai-compatible-endpoint/v1"
        }
      }
    }
  },
  "legacy": {
    "note": "Top-level provider blocks can remain for older installs, but new setup writes normalized ai examples above."
  },
  "channel": {
    "channelName": "Your Channel Name",
